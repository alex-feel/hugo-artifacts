# Copy to `.env` and fill in real values. NEVER commit a `.env` file with real secrets.
# Add `.env` to your project's .gitignore (already ignored by the repo-wide gitignore for
# this examples directory).

# Postgres connection string. Use sslmode=require for production deployments.
DATABASE_URL=postgres://user:password@localhost:5432/pwa_subscriptions

# VAPID identity. The subject is a contact URI (mailto: or https:) that push services use
# to reach the operator if delivery problems arise.
VAPID_SUBJECT=mailto:admin@example.com

# VAPID keypair. Generate via `npx web-push generate-vapid-keys`.
# The PUBLIC key also goes in your Hugo config as `params.pwa.push.vapid_public_key`.
# The PRIVATE key MUST stay server-side; never put it in the Hugo config or any client bundle.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# Comma-separated list of allowed origins for CORS / CSRF defense. Replace with the real
# consumer site origin(s) before deployment.
ALLOWED_ORIGINS=https://example.com,http://localhost:1313

# Strong random secret for the /trigger admin endpoint. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
ADMIN_KEY=

# HTTP listen port.
PORT=3000
